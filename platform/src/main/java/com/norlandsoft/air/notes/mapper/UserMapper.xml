<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.norlandsoft.air.notes.mapper.UserMapper">

  <resultMap id="UserResultMap" type="com.norlandsoft.air.notes.model.entity.User">
    <id column="id" property="id" jdbcType="VARCHAR"/>
    <result column="password" property="password" jdbcType="VARCHAR"/>
    <result column="salt" property="salt" jdbcType="VARCHAR"/>
    <result column="name" property="name" jdbcType="VARCHAR"/>
    <result column="avatar" property="avatar" jdbcType="VARCHAR"/>
    <result column="status" property="status" jdbcType="VARCHAR"/>
    <result column="role" property="role" jdbcType="VARCHAR"/>
    <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
    <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
  </resultMap>

  <sql id="Base_Column_List">
    id, password, salt, name, avatar, status, role, create_time, update_time
  </sql>

  <insert id="insert" parameterType="com.norlandsoft.air.notes.model.entity.User">
    INSERT INTO sys_user (id, password, salt, name, avatar, status, role, create_time, update_time)
    VALUES (#{id}, #{password}, #{salt}, #{name}, #{avatar}, #{status}, #{role}, #{createTime}, #{updateTime})
  </insert>

  <select id="selectById" resultMap="UserResultMap">
    SELECT <include refid="Base_Column_List"/>
    FROM sys_user
    WHERE id = #{id}
  </select>

  <update id="updatePassword">
    UPDATE sys_user
    SET password = #{password}, salt = #{salt}, update_time = CURRENT_TIMESTAMP
    WHERE id = #{id}
  </update>

</mapper>
